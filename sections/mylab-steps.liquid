{{ 'mylab-steps.css' | asset_url | stylesheet_tag }}

<section class="ml-steps" id="ml-steps-{{ section.id }}">
  <div class="ml-steps__container">

    {%- if section.settings.eyebrow != blank -%}
      <p class="ml-steps__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="ml-steps__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="ml-steps__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="ml-steps__grid">
      {%- for block in section.blocks -%}
        {%- capture step_num -%}
          {%- if forloop.index < 10 -%}0{{ forloop.index }}{%- else -%}{{ forloop.index }}{%- endif -%}
        {%- endcapture -%}

        {%- assign card_tag = 'div' -%}
        {%- if block.settings.link != blank -%}
          {%- assign card_tag = 'a' -%}
        {%- endif -%}

        <{{ card_tag }}
          class="ml-steps__card"
          data-index="{{ forloop.index0 }}"
          {%- if block.settings.link != blank %} href="{{ block.settings.link }}"{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="ml-steps__card-badge">{{ step_num }}</div>

          <div class="ml-steps__card-image">
            {%- if block.settings.image != blank -%}
              {{- block.settings.image | image_url: width: 600 | image_tag:
                class: 'ml-steps__img',
                alt: block.settings.title,
                loading: 'lazy'
              -}}
            {%- else -%}
              <div class="ml-steps__placeholder">
                {{- 'product-' | append: forloop.index | placeholder_svg_tag: 'ml-steps__placeholder-svg' -}}
              </div>
            {%- endif -%}
          </div>

          <div class="ml-steps__card-body">
            {%- if block.settings.title != blank -%}
              <h3 class="ml-steps__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="ml-steps__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        </{{ card_tag }}>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
(function () {
  var section = document.getElementById('ml-steps-{{ section.id }}');
  if (!section) return;
  var cards = section.querySelectorAll('.ml-steps__card');
  if (!cards.length) return;

  if (typeof IntersectionObserver === 'undefined') {
    cards.forEach(function (c) { c.classList.add('ml-steps__card--visible'); });
    return;
  }

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      var card = entry.target;
      var delay = parseInt(card.dataset.index, 10) * 130;
      setTimeout(function () {
        card.classList.add('ml-steps__card--visible');
      }, delay);
      observer.unobserve(card);
    });
  }, { threshold: 0.12 });

  cards.forEach(function (c) { observer.observe(c); });
})();
</script>

{% schema %}
{
  "name": "Étapes création de marque",
  "tag": "section",
  "class": "ml-steps-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texte d'accroche",
      "default": "Comment ça marche"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Les étapes de création de votre marque"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Lancez votre marque capillaire en quelques étapes simples, accompagné par nos équipes."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Titre de l'étape"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Décrivez cette étape en quelques mots."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Étapes création de marque",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "TESTEZ LES PRODUITS",
            "description": "Testez nos produits capillaires en format individuel ou via le coffret découverte avant de lancer votre gamme."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "DOSSIER COSMÉTOLOGIQUE",
            "description": "Notre équipe dépose votre marque sur le Portail de Notification des Produits Cosmétiques et crée vos codes-barres."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "PERSONNALISEZ VOS ÉTIQUETTES",
            "description": "Choisissez parmi nos modèles ou faites créer une étiquette sur mesure aux couleurs de votre marque."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "LA BOUTIQUE",
            "description": "Votre marque est validée. Commandez votre gamme à partir de 6 unités par référence depuis votre espace client."
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}

{% comment %}
  MyLab Shop — Calculateur de Profit
  sections/ml-profit-calculator.liquid
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ============================================================
     CALCULATEUR DE PROFIT — MyLab
     ============================================================ */

  .ml-calc-section {
    width: 100%;
    box-sizing: border-box;
    overflow-x: hidden;
  }

  .ml-calc {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 3rem;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .ml-calc__card {
    box-sizing: border-box;
    min-width: 0;
    max-width: 100%;
  }

  @media screen and (max-width: 989px) {
    .ml-calc {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  /* --- Intro --- */
  .ml-calc__intro-eyebrow {
    display: inline-block;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 1.2rem;
  }

  .ml-calc__intro-title {
    font-size: clamp(2.8rem, 4vw, 4.4rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 2rem;
    color: #111;
  }

  .ml-calc__intro-desc {
    font-size: 1.6rem;
    line-height: 1.75;
    color: rgba(17,17,17,0.6);
    margin: 0 0 3rem;
    max-width: 480px;
  }

  .ml-calc__intro-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .ml-calc__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.4rem;
    background: #f5f5f5;
    border-radius: 50px;
    font-size: 1.3rem;
    font-weight: 500;
    color: #444;
  }

  /* --- Carte calculateur --- */
  .ml-calc__card {
    background: #ffffff;
    border: 1px solid #ebebeb;
    border-radius: 24px;
    padding: 3.2rem;
    box-shadow: 0 8px 48px rgba(0,0,0,0.07);
  }

  /* Sélecteur produit */
  .ml-calc__product-selector {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    margin-bottom: 2.8rem;
    padding-bottom: 2.4rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .ml-calc__arrow {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border: 1px solid #e0e0e0;
    border-radius: 50%;
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    color: #111;
    padding: 0;
  }

  .ml-calc__arrow:hover:not(:disabled) {
    background: #f5f5f5;
    border-color: #bbb;
  }

  .ml-calc__arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }

  .ml-calc__product-info {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 1.4rem;
    min-width: 0;
  }

  .ml-calc__product-img {
    width: 56px;
    height: 56px;
    object-fit: contain;
    border-radius: 10px;
    background: #f8f8f8;
    flex-shrink: 0;
  }

  .ml-calc__product-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    background: #f0f0f0;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ml-calc__product-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: #111;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ml-calc__product-volume {
    font-size: 1.3rem;
    color: #999;
    margin-top: 3px;
  }

  /* Slider */
  .ml-calc__slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }

  .ml-calc__slider-label {
    font-size: 1.4rem;
    font-weight: 600;
    color: #111;
  }

  .ml-calc__slider-badge {
    background: #111;
    color: #fff;
    font-size: 1.3rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 50px;
    min-width: 42px;
    text-align: center;
  }

  .ml-calc__slider {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 5px;
    border-radius: 3px;
    background: #e0e0e0;
    outline: none;
    cursor: pointer;
    margin-bottom: 0.8rem;
  }

  .ml-calc__slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #111;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    transition: transform 0.1s;
  }

  .ml-calc__slider::-webkit-slider-thumb:hover {
    transform: scale(1.1);
  }

  .ml-calc__slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #111;
    cursor: pointer;
    border: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .ml-calc__tier-hint {
    font-size: 1.2rem;
    color: #888;
    margin-bottom: 2.4rem;
    min-height: 1.8rem;
  }

  .ml-calc__tier-hint--best {
    color: #2d7a45;
    font-weight: 500;
  }

  /* Onglets */
  .ml-calc__tabs {
    display: flex;
    background: #f5f5f5;
    border-radius: 50px;
    padding: 4px;
    gap: 4px;
    margin-bottom: 2.4rem;
  }

  .ml-calc__tab {
    flex: 1;
    padding: 8px 16px;
    border: none;
    border-radius: 50px;
    font-size: 1.3rem;
    font-weight: 500;
    cursor: pointer;
    background: transparent;
    color: #777;
    transition: background 0.15s, color 0.15s;
    font-family: inherit;
    white-space: nowrap;
  }

  .ml-calc__tab.is-active {
    background: #111;
    color: #fff;
  }

  /* Résultats */
  .ml-calc__results {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.4rem;
  }

  .ml-calc__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .ml-calc__row-label {
    font-size: 1.4rem;
    color: #777;
  }

  .ml-calc__row-value {
    font-size: 1.45rem;
    font-weight: 500;
    color: #111;
    white-space: nowrap;
  }

  .ml-calc__row--total {
    padding-top: 1.4rem;
    margin-top: 0.4rem;
    border-top: 1px solid #ebebeb;
  }

  .ml-calc__row--total .ml-calc__row-label {
    font-size: 1.7rem;
    font-weight: 700;
    color: #111;
  }

  .ml-calc__row--total .ml-calc__row-value {
    font-size: 1.9rem;
    font-weight: 700;
    color: #111;
  }

  /* CTA */
  .ml-calc__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 1.4rem 2.4rem;
    background: #111;
    color: #fff;
    border-radius: 50px;
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
    font-family: inherit;
  }

  .ml-calc__cta:hover {
    background: #333;
    color: #fff;
  }

  .ml-calc__footnote {
    font-size: 1.2rem;
    color: #bbb;
    text-align: center;
    margin-top: 1.6rem;
    line-height: 1.6;
  }

  /* ============================================================
     RESPONSIVE — Tablette (≤ 989px)
     ============================================================ */
  @media screen and (max-width: 989px) {
    .ml-calc {
      padding: 0 2.4rem;
    }

    .ml-calc__intro {
      text-align: center;
    }

    .ml-calc__intro-desc {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    .ml-calc__intro-badges {
      justify-content: center;
    }

    .ml-calc__intro-title {
      font-size: clamp(2.4rem, 5vw, 3.6rem);
    }
  }

  /* ============================================================
     RESPONSIVE — Mobile (≤ 749px)
     ============================================================ */
  @media screen and (max-width: 749px) {
    .ml-calc {
      padding: 0 1.6rem;
      gap: 3.2rem;
    }

    /* Carte : padding réduit, contrainte absolue de largeur */
    .ml-calc__card {
      padding: 2rem 1.6rem;
      border-radius: 18px;
      width: 100%;
      max-width: calc(100vw - 3.2rem);
      overflow: hidden;
    }

    /* Sélecteur produit : flèches plus grandes (touch target 44px) */
    .ml-calc__arrow {
      width: 40px;
      height: 40px;
      flex-shrink: 0;
    }

    .ml-calc__product-selector {
      gap: 1rem;
      margin-bottom: 2rem;
      padding-bottom: 2rem;
    }

    .ml-calc__product-img,
    .ml-calc__product-placeholder {
      width: 48px;
      height: 48px;
    }

    .ml-calc__product-name {
      font-size: 1.4rem;
      white-space: normal;
      word-break: break-word;
    }

    /* Slider : thumb plus grand pour le touch */
    .ml-calc__slider {
      height: 6px;
      margin-bottom: 1rem;
    }

    .ml-calc__slider::-webkit-slider-thumb {
      width: 28px;
      height: 28px;
    }

    .ml-calc__slider::-moz-range-thumb {
      width: 28px;
      height: 28px;
    }

    .ml-calc__slider-badge {
      font-size: 1.4rem;
      padding: 5px 14px;
    }

    .ml-calc__tier-hint {
      font-size: 1.15rem;
      margin-bottom: 2rem;
    }

    /* Onglets : wrapping autorisé, nowrap supprimé */
    .ml-calc__tabs {
      gap: 3px;
    }

    .ml-calc__tab {
      font-size: 1.15rem;
      padding: 7px 8px;
      white-space: normal;
      text-align: center;
      line-height: 1.3;
    }

    /* Lignes résultats */
    .ml-calc__row {
      flex-wrap: wrap;
      gap: 0.3rem;
    }

    .ml-calc__row-label {
      font-size: 1.3rem;
      flex: 1 1 50%;
      white-space: normal;
    }

    .ml-calc__row-value {
      font-size: 1.35rem;
      text-align: right;
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .ml-calc__row--total .ml-calc__row-label {
      font-size: 1.5rem;
    }

    .ml-calc__row--total .ml-calc__row-value {
      font-size: 1.6rem;
    }

    /* Slider badge : ne doit pas déborder */
    .ml-calc__slider-header {
      gap: 0.8rem;
    }

    /* CTA : padding généreux pour le touch */
    .ml-calc__cta {
      padding: 1.6rem 2rem;
      font-size: 1.45rem;
    }

    /* Titre intro */
    .ml-calc__intro-title {
      font-size: clamp(2.4rem, 7vw, 3.2rem);
    }

    .ml-calc__intro-desc {
      font-size: 1.5rem;
    }
  }

  /* ============================================================
     RESPONSIVE — Très petit mobile (≤ 390px)
     ============================================================ */
  @media screen and (max-width: 390px) {
    .ml-calc {
      padding: 0 1.2rem;
    }

    .ml-calc__card {
      padding: 1.6rem 1.4rem;
    }

    .ml-calc__tabs {
      flex-direction: column;
      border-radius: 14px;
    }

    .ml-calc__tab {
      border-radius: 10px;
      text-align: center;
    }
  }
</style>

{%- comment -%} Données produits injectées pour le JS {%- endcomment -%}
<script type="application/json" id="ml-calc-data-{{ section.id }}">
  {
    "products": [
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {
            "label": {{ block.settings.label | json }},
            "volume": {{ block.settings.volume | json }},
            "retailPrice": {{ block.settings.retail_price | times: 100 | round }},
            "url": {% if block.settings.product != blank %}{{ block.settings.product.url | json }}{% else %}"#"{% endif %},
            "image": {% if block.settings.product != blank and block.settings.product.featured_image != blank %}{{ block.settings.product.featured_image | image_url: width: 200 | json }}{% else %}null{% endif %},
            "tiers": {{ block.settings.tiers_json }},
            "maxQty": {{ block.settings.max_qty }}
          }{% unless forloop.last %},{% endunless %}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
</script>

<section class="ml-calc-section color-{{ section.settings.color_scheme }} gradient">
  <div class="ml-calc">

    {%- comment -%} ===== INTRO GAUCHE ===== {%- endcomment -%}
    <div class="ml-calc__intro">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ml-calc__intro-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="ml-calc__intro-title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="ml-calc__intro-desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="ml-calc__intro-badges">
        <span class="ml-calc__badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="#2d7a45" stroke-width="1.5" stroke-linecap="round"/></svg>
          Tarifs dégressifs
        </span>
        <span class="ml-calc__badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="#2d7a45" stroke-width="1.5" stroke-linecap="round"/></svg>
          Formules professionnelles
        </span>
        <span class="ml-calc__badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="#2d7a45" stroke-width="1.5" stroke-linecap="round"/></svg>
          Sans engagement
        </span>
      </div>
    </div>

    {%- comment -%} ===== CARTE CALCULATEUR ===== {%- endcomment -%}
    <div class="ml-calc__card" id="ml-calc-card-{{ section.id }}">

      {%- comment -%} Sélecteur produit {%- endcomment -%}
      <div class="ml-calc__product-selector">
        <button class="ml-calc__arrow" id="ml-calc-prev-{{ section.id }}" aria-label="Produit précédent" disabled>
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="ml-calc__product-info" id="ml-calc-product-{{ section.id }}">
          <div class="ml-calc__product-placeholder">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" opacity="0.3"><path d="M3 7h18l-2 13H5L3 7z" stroke="currentColor" stroke-width="1.5"/><path d="M8 7V5a4 4 0 018 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div>
            <div class="ml-calc__product-name">Chargement…</div>
            <div class="ml-calc__product-volume">—</div>
          </div>
        </div>
        <button class="ml-calc__arrow" id="ml-calc-next-{{ section.id }}" aria-label="Produit suivant">
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none"><path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

      {%- comment -%} Slider quantité {%- endcomment -%}
      <div class="ml-calc__slider-header">
        <span class="ml-calc__slider-label">Quantité</span>
        <span class="ml-calc__slider-badge" id="ml-calc-qty-{{ section.id }}">—</span>
      </div>
      <input
        type="range"
        class="ml-calc__slider"
        id="ml-calc-slider-{{ section.id }}"
        min="1" max="200" value="12"
        aria-label="Quantité"
      >
      <div class="ml-calc__tier-hint" id="ml-calc-hint-{{ section.id }}"></div>

      {%- comment -%} Onglets {%- endcomment -%}
      <div class="ml-calc__tabs">
        <button class="ml-calc__tab" data-tab="savings">Économies</button>
        <button class="ml-calc__tab is-active" data-tab="roi">Retour sur investissement</button>
      </div>

      {%- comment -%} Résultats {%- endcomment -%}
      <div class="ml-calc__results" id="ml-calc-results-{{ section.id }}"></div>

      {%- comment -%} Bouton {%- endcomment -%}
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="ml-calc__cta" id="ml-calc-cta-{{ section.id }}">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h12M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {{ section.settings.cta_label | default: 'Commander maintenant' }}
      </a>

      {%- if section.settings.footnote != blank -%}
        <p class="ml-calc__footnote">{{ section.settings.footnote }}</p>
      {%- endif -%}

    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  var sectionId = {{ section.id | json }};

  // Lecture des données produits
  var dataEl = document.getElementById('ml-calc-data-' + sectionId);
  if (!dataEl) return;

  var data;
  try { data = JSON.parse(dataEl.textContent); } catch(e) { return; }

  var products = data.products;
  if (!products || products.length === 0) return;

  // État
  var state = { productIndex: 0, qty: 0, tab: 'roi' };

  // DOM
  var elProduct = document.getElementById('ml-calc-product-' + sectionId);
  var elSlider  = document.getElementById('ml-calc-slider-' + sectionId);
  var elQty     = document.getElementById('ml-calc-qty-' + sectionId);
  var elHint    = document.getElementById('ml-calc-hint-' + sectionId);
  var elResults = document.getElementById('ml-calc-results-' + sectionId);
  var elPrev    = document.getElementById('ml-calc-prev-' + sectionId);
  var elNext    = document.getElementById('ml-calc-next-' + sectionId);
  var elCta     = document.getElementById('ml-calc-cta-' + sectionId);
  var tabs      = document.querySelectorAll('#ml-calc-card-' + sectionId + ' .ml-calc__tab');

  function fmt(cents) {
    return (cents / 100).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '\u00a0€';
  }

  function getPricePerUnit(product, qty) {
    var price = product.tiers[0].price;
    for (var i = 0; i < product.tiers.length; i++) {
      if (qty >= product.tiers[i].qty) price = product.tiers[i].price;
    }
    return price;
  }

  function getNextTier(product, qty) {
    for (var i = 0; i < product.tiers.length; i++) {
      if (qty < product.tiers[i].qty) return product.tiers[i];
    }
    return null;
  }

  function updateSlider(product) {
    var minQty    = product.tiers[0].qty;
    var maxSlider = (product.maxQty > 0) ? product.maxQty : product.tiers[product.tiers.length - 1].qty * 3;

    elSlider.min   = minQty;
    elSlider.max   = maxSlider;
    state.qty      = Math.max(minQty, Math.min(state.qty || minQty, maxSlider));
    elSlider.value = state.qty;
  }

  function updateSliderTrack() {
    var min = parseFloat(elSlider.min);
    var max = parseFloat(elSlider.max);
    var val = parseFloat(elSlider.value);
    var pct = ((val - min) / (max - min)) * 100;
    elSlider.style.background =
      'linear-gradient(to right, #111 ' + pct + '%, #e0e0e0 ' + pct + '%)';
  }

  function renderProduct() {
    var p = products[state.productIndex];

    var imgHtml = p.image
      ? '<img src="' + p.image + '" alt="' + p.label + '" class="ml-calc__product-img">'
      : '<div class="ml-calc__product-placeholder"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" opacity="0.3"><path d="M3 7h18l-2 13H5L3 7z" stroke="currentColor" stroke-width="1.5"/></svg></div>';

    elProduct.innerHTML =
      imgHtml +
      '<div>' +
        '<div class="ml-calc__product-name">' + p.label + '</div>' +
        '<div class="ml-calc__product-volume">' + p.volume + '</div>' +
      '</div>';

    if (elCta && p.url && p.url !== '#') {
      elCta.href = p.url;
    }

    elPrev.disabled = state.productIndex === 0;
    elNext.disabled = state.productIndex === products.length - 1;

    updateSlider(p);
    renderResults();
  }

  function renderResults() {
    var p            = products[state.productIndex];
    var qty          = state.qty;
    var priceUnit    = getPricePerUnit(p, qty);
    var totalCost    = priceUnit * qty;
    var retailUnit   = p.retailPrice;
    var totalEarnings = retailUnit * qty;
    var profit       = totalEarnings - totalCost;
    var roi          = totalCost > 0 ? Math.round((profit / totalCost) * 100) : 0;
    var catalogUnit  = p.tiers[0].price;
    var catalogTotal = catalogUnit * qty;
    var savings      = catalogTotal - totalCost;

    // Mise à jour affichage quantité
    elQty.textContent = qty;
    updateSliderTrack();

    // Hint palier suivant
    var next = getNextTier(p, qty);
    if (next) {
      var diff = next.qty - qty;
      elHint.textContent = 'Encore\u00a0' + diff + '\u00a0unité' + (diff > 1 ? 's' : '') + ' pour atteindre\u00a0' + fmt(next.price) + '/unité';
      elHint.className = 'ml-calc__tier-hint';
    } else {
      elHint.textContent = 'Vous bénéficiez du meilleur tarif !';
      elHint.className = 'ml-calc__tier-hint ml-calc__tier-hint--best';
    }

    var html = '';

    if (state.tab === 'roi') {
      html =
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">PVC conseillé (unité)</span>' +
          '<span class="ml-calc__row-value">' + fmt(retailUnit) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">Prix d\'achat (' + qty + ' unités)</span>' +
          '<span class="ml-calc__row-value">' + fmt(totalCost) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">Total bénéfices clients</span>' +
          '<span class="ml-calc__row-value">' + fmt(totalEarnings) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row ml-calc__row--total">' +
          '<span class="ml-calc__row-label">Votre profit</span>' +
          '<span class="ml-calc__row-value">' + fmt(profit) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">Retour sur investissement</span>' +
          '<span class="ml-calc__row-value">' + roi + '\u00a0%</span>' +
        '</div>';
    } else {
      html =
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">Prix unitaire catalogue</span>' +
          '<span class="ml-calc__row-value">' + fmt(catalogUnit) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">Votre prix unitaire</span>' +
          '<span class="ml-calc__row-value">' + fmt(priceUnit) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">Total catalogue (' + qty + ' unités)</span>' +
          '<span class="ml-calc__row-value">' + fmt(catalogTotal) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row ml-calc__row--total">' +
          '<span class="ml-calc__row-label">Économies réalisées</span>' +
          '<span class="ml-calc__row-value">' + fmt(savings) + '</span>' +
        '</div>' +
        '<div class="ml-calc__row">' +
          '<span class="ml-calc__row-label">Prix d\'achat total</span>' +
          '<span class="ml-calc__row-value">' + fmt(totalCost) + '</span>' +
        '</div>';
    }

    elResults.innerHTML = html;
  }

  // === ÉVÉNEMENTS ===
  elPrev.addEventListener('click', function() {
    if (state.productIndex > 0) { state.productIndex--; renderProduct(); }
  });

  elNext.addEventListener('click', function() {
    if (state.productIndex < products.length - 1) { state.productIndex++; renderProduct(); }
  });

  elSlider.addEventListener('input', function() {
    state.qty = parseInt(elSlider.value);
    renderResults();
  });

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      state.tab = tab.dataset.tab;
      tabs.forEach(function(t) { t.classList.remove('is-active'); });
      tab.classList.add('is-active');
      renderResults();
    });
  });

  // Init
  renderProduct();

})();
</script>


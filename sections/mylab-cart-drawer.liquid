{% comment %}
  MyLab Shop — Panier tiroir custom
  Fichier : sections/mylab-cart-drawer.liquid

  À inclure dans layout/theme.liquid juste avant </body>
  via : {% section 'mylab-cart-drawer' %}
{% endcomment %}

{{ 'mylab-product.css' | asset_url | stylesheet_tag }}

<div class="ml-drawer-overlay" id="ml-drawer-overlay" aria-hidden="true"></div>

<div class="ml-drawer" id="ml-cart-drawer" role="dialog" aria-label="Votre panier" aria-modal="true" aria-hidden="true">

  {%- comment -%} HEADER {%- endcomment -%}
  <div class="ml-drawer__header">
    <div class="ml-drawer__title">
      <span>Votre panier</span>
      <span class="ml-drawer__count" id="ml-drawer-count">0</span>
    </div>
    <button class="ml-drawer__close" id="ml-drawer-close" aria-label="Fermer le panier">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  {%- comment -%} CONTENU DYNAMIQUE {%- endcomment -%}
  <div class="ml-drawer__body" id="ml-drawer-body">

    {%- comment -%} État vide {%- endcomment -%}
    <div class="ml-drawer__empty" id="ml-drawer-empty">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" opacity="0.2">
        <path d="M8 12h32l-4 20H12L8 12z" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="18" cy="38" r="2" fill="currentColor"/>
        <circle cx="32" cy="38" r="2" fill="currentColor"/>
        <path d="M4 6h4l4 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p>Votre panier est vide</p>
    </div>

    {%- comment -%} Liste des articles {%- endcomment -%}
    <div class="ml-drawer__items" id="ml-drawer-items"></div>

  </div>

  {%- comment -%} FOOTER {%- endcomment -%}
  <div class="ml-drawer__footer" id="ml-drawer-footer" style="display:none">

    <div class="ml-drawer__subtotal-block">
      <span class="ml-drawer__subtotal-label">Sous-total HT estimé</span>
      <span class="ml-drawer__subtotal-amount" id="ml-drawer-subtotal">—</span>
    </div>

    <a href="/checkout" class="ml-btn-checkout">
      Passer la commande
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <a href="/cart" class="ml-btn-cart-page">Voir le panier complet</a>

  </div>

</div>

{% schema %}
{
  "name": "MyLab — Panier tiroir",
  "tag": "section",
  "settings": []
}
{% endschema %}

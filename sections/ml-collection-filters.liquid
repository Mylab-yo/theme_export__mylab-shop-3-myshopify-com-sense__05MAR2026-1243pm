{%- style -%}
/* ================================================================
   ML COLLECTION FILTERS — Barre de filtres personnalisable
   ================================================================ */

.ml-cf {
  background: #f8f8f7;
  border-bottom: 1px solid #e8e8e8;
  position: relative;
}

.ml-cf__bar {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  padding: 1rem 0;
  overflow-x: auto;
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.ml-cf__bar::-webkit-scrollbar { display: none; }

.ml-cf__groups {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex: 1;
  min-width: 0;
  flex-wrap: nowrap;
}

/* ---- Pill (summary) ---- */
.ml-cf__group {
  position: relative;
  flex-shrink: 0;
}

.ml-cf__pill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1.2rem;
  background: #fff;
  border: 1px solid #d0d0d0;
  border-radius: 8px;
  font-size: 1.4rem;
  font-weight: 500;
  color: #111;
  cursor: pointer;
  list-style: none;
  white-space: nowrap;
  line-height: 1.3;
  transition: border-color 0.15s ease, background 0.15s ease;
  user-select: none;
}

.ml-cf__pill::-webkit-details-marker,
.ml-cf__pill::marker { display: none; }

.ml-cf__pill:hover { border-color: #111; }

.ml-cf__group[open] > .ml-cf__pill,
.ml-cf__pill--active {
  background: #111;
  color: #fff;
  border-color: #111;
  box-shadow: 0 0 0 1px #111;
}

.ml-cf__pill-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.25);
  color: #fff;
  border-radius: 50px;
  font-size: 1.1rem;
  font-weight: 700;
  min-width: 18px;
  height: 18px;
  padding: 0 4px;
  line-height: 1;
}

.ml-cf__pill-caret {
  width: 10px;
  height: 6px;
  flex-shrink: 0;
  transition: transform 0.2s ease;
  color: #888;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.ml-cf__group[open] > .ml-cf__pill .ml-cf__pill-caret {
  transform: rotate(180deg);
  color: #fff;
}

.ml-cf__pill--active .ml-cf__pill-caret { color: #fff; }

/* ---- Dropdown — position: fixed via JS pour échapper au overflow-x: auto ---- */
.ml-cf__dropdown {
  position: fixed;
  min-width: 220px;
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  z-index: 9999;
  overflow: hidden;
  padding: 0.6rem 0;
  display: none;
}

.ml-cf__dropdown.is-open {
  display: block;
}

.ml-cf__item { margin: 0; padding: 0; }

.ml-cf__label {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem 1.6rem;
  font-size: 1.4rem;
  font-weight: 400;
  color: #111;
  cursor: pointer;
  transition: background 0.1s;
  user-select: none;
}

.ml-cf__label:hover { background: #f5f5f5; }

.ml-cf__label input[type='checkbox'] {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  accent-color: #111;
  cursor: pointer;
}

/* ---- Sort ---- */
.ml-cf__sort {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-shrink: 0;
  margin-left: auto;
  padding-left: 1.6rem;
  border-left: 1px solid #e8e8e8;
}

.ml-cf__sort-label {
  font-size: 1.35rem;
  font-weight: 500;
  color: #666;
  white-space: nowrap;
}

.ml-cf__sort-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.ml-cf__sort-select {
  appearance: none;
  -webkit-appearance: none;
  background: transparent;
  border: none;
  font-size: 1.35rem;
  font-weight: 600;
  color: #111;
  cursor: pointer;
  padding: 0 1.8rem 0 0;
  outline: none;
  font-family: inherit;
}

.ml-cf__sort-wrap svg {
  position: absolute;
  right: 0;
  pointer-events: none;
  color: #666;
  width: 10px;
  height: 6px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.5;
  stroke-linecap: round;
}

/* ---- Active chips ---- */
.ml-cf__active {
  display: none;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.6rem;
  padding: 0.8rem 0 0.4rem;
}

.ml-cf__chip {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.4rem 1rem;
  background: #111;
  color: #fff;
  border: none;
  border-radius: 50px;
  font-size: 1.2rem;
  font-weight: 500;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.15s;
}

.ml-cf__chip:hover { background: #333; }
.ml-cf__chip-x { opacity: 0.6; margin-left: 2px; }

.ml-cf__chip-clear {
  font-size: 1.2rem;
  font-weight: 500;
  color: #888;
  background: none;
  border: none;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 2px;
  font-family: inherit;
  padding: 0.4rem;
}

.ml-cf__chip-clear:hover { color: #111; }

/* ---- Mobile ---- */
@media (max-width: 989px) {
  .ml-cf {
    background: transparent;
    border-bottom: none;
  }
}
{%- endstyle -%}

<div class="ml-cf" data-section-id="{{ section.id }}">
  <div class="ml-cf__bar page-width">

    <div class="ml-cf__groups" id="ml-cf-groups-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'filter_group' -%}
          {%- assign raw_values = block.settings.values | remove: "\r" | strip -%}
          {%- assign value_lines = raw_values | split: "\n" -%}

          <details
            class="ml-cf__group"
            id="ml-cf-group-{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <summary class="ml-cf__pill" id="ml-cf-pill-{{ block.id }}">
              <span class="ml-cf__pill-text">{{ block.settings.label }}</span>
              <span class="ml-cf__pill-badge" style="display:none" aria-hidden="true"></span>
              <svg class="ml-cf__pill-caret" viewBox="0 0 10 6"><path d="M1 1L5 5L9 1"/></svg>
            </summary>

            <div class="ml-cf__dropdown">
              {%- for line in value_lines -%}
                {%- assign line_clean = line | strip -%}
                {%- unless line_clean == blank -%}
                  {%- assign parts = line_clean | split: "|" -%}
                  {%- assign v_label = parts[0] | strip -%}
                  {%- if parts.size > 1 -%}
                    {%- assign v_value = parts[1] | strip | downcase -%}
                  {%- else -%}
                    {%- assign v_value = v_label | downcase -%}
                  {%- endif -%}
                  <div class="ml-cf__item">
                    <label class="ml-cf__label">
                      <input
                        type="checkbox"
                        class="ml-cf__checkbox"
                        data-filter-type="{{ block.settings.filter_type }}"
                        data-filter-value="{{ v_value | url_encode }}"
                        data-filter-label="{{ v_label | escape }}"
                      >
                      <span>{{ v_label }}</span>
                    </label>
                  </div>
                {%- endunless -%}
              {%- endfor -%}
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_sort -%}
      <div class="ml-cf__sort">
        <span class="ml-cf__sort-label">Trier par</span>
        <div class="ml-cf__sort-wrap">
          {%- assign current_sort = collection.sort_by | default: collection.default_sort_by -%}
          <select class="ml-cf__sort-select" id="ml-cf-sort-{{ section.id }}">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value | escape }}"{% if option.value == current_sort %} selected{% endif %}>
                {{ option.name | escape }}
              </option>
            {%- endfor -%}
          </select>
          <svg viewBox="0 0 10 6"><path d="M1 1L5 5L9 1" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg>
        </div>
      </div>
    {%- endif -%}

  </div>

  <div class="ml-cf__active page-width" id="ml-cf-active-{{ section.id }}"></div>
</div>

<script>
(function() {
  'use strict';

  var SID = {{ section.id | json }};

  /* --- Utilitaires URL --- */
  function getParams() {
    return new URLSearchParams(window.location.search);
  }

  function paramKey(filterType) {
    var map = {
      'tag':          'filter.p.tag',
      'product_type': 'filter.p.product_type',
      'vendor':       'filter.p.vendor'
    };
    return map[filterType] || 'filter.p.tag';
  }

  function getActiveValues(filterType) {
    return getParams().getAll(paramKey(filterType));
  }

  function applyFilters(filterType, newValues) {
    var params = getParams();
    var key = paramKey(filterType);
    params.delete(key);
    newValues.forEach(function(v) { params.append(key, v); });
    params.delete('page');
    window.location.search = params.toString();
  }

  function clearAllFilters() {
    var params = getParams();
    Array.from(params.keys()).forEach(function(k) {
      if (k.startsWith('filter.')) params.delete(k);
    });
    params.delete('page');
    window.location.search = params.toString();
  }

  /* --- Synchronisation des checkboxes --- */
  function syncCheckboxes() {
    document.querySelectorAll('#ml-cf-groups-' + SID + ' .ml-cf__checkbox').forEach(function(cb) {
      var active = getActiveValues(cb.dataset.filterType);
      cb.checked = active.indexOf(decodeURIComponent(cb.dataset.filterValue)) !== -1;
    });
  }

  /* --- Mise à jour des badges sur les pills --- */
  function updateBadges() {
    document.querySelectorAll('#ml-cf-groups-' + SID + ' .ml-cf__group').forEach(function(group) {
      var checked = group.querySelectorAll('.ml-cf__checkbox:checked').length;
      var badge   = group.querySelector('.ml-cf__pill-badge');
      var pill    = group.querySelector('.ml-cf__pill');
      if (checked > 0) {
        badge.textContent = checked;
        badge.style.display = '';
        pill.classList.add('ml-cf__pill--active');
      } else {
        badge.style.display = 'none';
        pill.classList.remove('ml-cf__pill--active');
      }
    });
  }

  /* --- Rendu des chips actifs sous la barre --- */
  function renderChips() {
    var container = document.getElementById('ml-cf-active-' + SID);
    if (!container) return;

    var params = getParams();
    var chips  = [];

    params.forEach(function(value, key) {
      if (key.startsWith('filter.')) {
        /* Retrouve le label lisible depuis les checkboxes */
        var label = value;
        var cb = document.querySelector(
          '#ml-cf-groups-' + SID +
          ' .ml-cf__checkbox[data-filter-value="' + encodeURIComponent(value) + '"]'
        );
        if (cb && cb.dataset.filterLabel) label = cb.dataset.filterLabel;

        chips.push({ key: key, value: value, label: label });
      }
    });

    if (chips.length === 0) {
      container.style.display = 'none';
      container.innerHTML = '';
      return;
    }

    container.style.display = 'flex';
    container.innerHTML = chips.map(function(c) {
      return '<button class="ml-cf__chip" data-key="' + c.key + '" data-value="' + c.value + '">' +
             c.label +
             '<span class="ml-cf__chip-x" aria-hidden="true">×</span>' +
             '</button>';
    }).join('') +
    '<button class="ml-cf__chip-clear">Tout effacer</button>';

    /* Supprime un chip individuel */
    container.querySelectorAll('.ml-cf__chip').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var params = getParams();
        var kept = params.getAll(btn.dataset.key).filter(function(v) {
          return v !== btn.dataset.value;
        });
        params.delete(btn.dataset.key);
        kept.forEach(function(v) { params.append(btn.dataset.key, v); });
        params.delete('page');
        window.location.search = params.toString();
      });
    });

    /* Efface tout */
    var clearBtn = container.querySelector('.ml-cf__chip-clear');
    if (clearBtn) {
      clearBtn.addEventListener('click', clearAllFilters);
    }
  }

  /* --- Init --- */
  document.addEventListener('DOMContentLoaded', function() {
    syncCheckboxes();
    updateBadges();
    renderChips();

    /* Checkboxes */
    document.querySelectorAll('#ml-cf-groups-' + SID + ' .ml-cf__checkbox').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var active = getActiveValues(cb.dataset.filterType);
        var val    = decodeURIComponent(cb.dataset.filterValue);
        var idx    = active.indexOf(val);
        if (cb.checked && idx === -1) {
          active.push(val);
        } else if (!cb.checked && idx !== -1) {
          active.splice(idx, 1);
        }
        applyFilters(cb.dataset.filterType, active);
      });
    });

    /* Tri */
    var sortSel = document.getElementById('ml-cf-sort-' + SID);
    if (sortSel) {
      sortSel.addEventListener('change', function() {
        var params = getParams();
        params.set('sort_by', this.value);
        params.delete('page');
        window.location.search = params.toString();
      });
    }

    /* ---- Gestion custom des dropdowns (position: fixed) ---- */
    var openGroup = null;

    function positionDropdown(group) {
      var pill     = group.querySelector('.ml-cf__pill');
      var dropdown = group.querySelector('.ml-cf__dropdown');
      if (!pill || !dropdown) return;
      var rect = pill.getBoundingClientRect();
      dropdown.style.top  = (rect.bottom + 6) + 'px';
      dropdown.style.left = rect.left + 'px';
    }

    function openDropdown(group) {
      if (openGroup && openGroup !== group) closeDropdown(openGroup);
      var dropdown = group.querySelector('.ml-cf__dropdown');
      var pill     = group.querySelector('.ml-cf__pill');
      if (!dropdown) return;
      positionDropdown(group);
      dropdown.classList.add('is-open');
      openGroup = group;
    }

    function closeDropdown(group) {
      var dropdown = group.querySelector('.ml-cf__dropdown');
      if (!dropdown) return;
      dropdown.classList.remove('is-open');
      if (openGroup === group) openGroup = null;
    }

    /* Intercepte les clics sur les pills */
    document.querySelectorAll('#ml-cf-groups-' + SID + ' .ml-cf__pill').forEach(function(pill) {
      pill.addEventListener('click', function(e) {
        e.preventDefault();
        var group = pill.closest('.ml-cf__group');
        if (openGroup === group && group.querySelector('.ml-cf__dropdown.is-open')) {
          closeDropdown(group);
        } else {
          openDropdown(group);
        }
      });
    });

    /* Empêche la fermeture en cliquant dans le dropdown */
    document.querySelectorAll('#ml-cf-groups-' + SID + ' .ml-cf__dropdown').forEach(function(dd) {
      dd.addEventListener('click', function(e) { e.stopPropagation(); });
    });

    /* Ferme au clic extérieur */
    document.addEventListener('click', function(e) {
      if (openGroup && !e.target.closest('#ml-cf-groups-' + SID)) {
        closeDropdown(openGroup);
      }
    });

    /* Repositionne au scroll/resize */
    window.addEventListener('scroll', function() {
      if (openGroup) positionDropdown(openGroup);
    }, { passive: true });
    window.addEventListener('resize', function() {
      if (openGroup) positionDropdown(openGroup);
    });
  });

})();
</script>

{% schema %}
{
  "name": "Filtres collection",
  "tag": "div",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Afficher le tri",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "filter_group",
      "name": "Groupe de filtres",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Libellé du filtre",
          "default": "Gamme"
        },
        {
          "type": "select",
          "id": "filter_type",
          "label": "Type de filtre Shopify",
          "info": "Tag = filtre par tag produit. Type = filtre par type de produit.",
          "options": [
            { "value": "tag",          "label": "Tag produit" },
            { "value": "product_type", "label": "Type de produit" },
            { "value": "vendor",       "label": "Fournisseur" }
          ],
          "default": "tag"
        },
        {
          "type": "textarea",
          "id": "values",
          "label": "Valeurs (une par ligne)",
          "info": "Format : Libellé | valeur_tag  — ex: Nourrissant | nourrissant",
          "default": "Nourrissant | nourrissant\nVolume | volume\nLissant | lissant"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Filtres collection",
      "blocks": [
        {
          "type": "filter_group",
          "settings": {
            "label": "Gamme",
            "filter_type": "tag",
            "values": "Nourrissant | nourrissant\nVolume | volume\nLissant | lissant\nBoucles | boucles\nPurifiant | purifiant"
          }
        },
        {
          "type": "filter_group",
          "settings": {
            "label": "Contenance",
            "filter_type": "tag",
            "values": "200 ml | 200ml\n500 ml | 500ml\n1000 ml | 1000ml"
          }
        },
        {
          "type": "filter_group",
          "settings": {
            "label": "Type",
            "filter_type": "product_type",
            "values": "Shampoing | Shampoing\nMasque | Masque\nCrème | Crème\nSoin | Soin"
          }
        }
      ]
    }
  ]
}
{% endschema %}
